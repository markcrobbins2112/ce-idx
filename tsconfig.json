{
	"compilerOptions": {
		"forceConsistentCasingInFileNames": true,
		"module": "ESNext",
		"target": "ESNext",
		"moduleResolution": "Bundler",
		"lib": [
			"ESNext"
		],
		"types": [
			"vscode",
			"node",
			"bun"
		],
		"strict": false,
		"allowJs": true,
		"noEmit": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"ignoreDeprecations": "6.0",
		"baseUrl": ".",
		"paths": {
			"*": [
				"./src/*"
			]
		}
	},
	"include": [
		"src/**/*"
	]
}
